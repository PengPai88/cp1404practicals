BoxLayout:
    orientation: 'horizontal'

    BoxLayout:
        orientation: 'vertical'
        size_hint_x: 0.2

        Button:
            text: 'Clear'
            on_press: app.handle_clear()
            font_size: 32

        Button:
            text: 'Greet'
            on_press: app.handle_greet()
            font_size: 32

    BoxLayout:
        orientation: 'vertical'

        TextInput:
            id: input_name
            text: ''
            font_size: 32

        Label:
            id: output_label
            text: ''
            color: (1, 1, 0, 1)
            font_size: 32